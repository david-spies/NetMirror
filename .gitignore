# ─── NetMirror — .gitignore ───────────────────────────────────────────────────

# ── Capture & Report Output ───────────────────────────────────────────────────
# PCAP files contain raw packet payloads and may include sensitive data
# (credentials, session tokens, PII). Never commit these.
captures/*
reports/*

# Keep the placeholder files so empty dirs are tracked by git
!captures/.gitkeep
!reports/.gitkeep

# Explicit file-type guards (catches any stray files outside the above dirs)
*.pcap
*.pcapng
*.cap
*.dmp

# JSON reports generated by the export endpoint
*_report_*.json


# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo

# C extensions
*.so

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
MANIFEST

# PyInstaller (if ever bundled as an executable)
*.spec
*.manifest


# ── Virtual Environments ──────────────────────────────────────────────────────
venv/
.venv/
env/
.env/
ENV/
virtualenv/

# pipenv
Pipfile.lock

# poetry
poetry.lock


# ── Environment & Secrets ─────────────────────────────────────────────────────
# If a .env file is ever added for config (SECRET_KEY, etc.), keep it local
.env
.env.*
!.env.example

# Local config overrides
config.local.py
settings.local.py


# ── IDE & Editor ──────────────────────────────────────────────────────────────
# VS Code
.vscode/
*.code-workspace

# JetBrains (PyCharm, IntelliJ)
.idea/
*.iml
*.iws
*.ipr

# Vim
*.swp
*.swo
*~
.netrwhist

# Emacs
\#*\#
.\#*

# Sublime Text
*.sublime-project
*.sublime-workspace

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
.directory


# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/
log/


# ── Testing ───────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
nosetests.xml
coverage.xml
*.cover
*.hypothesis/


# ── Jupyter (if notebooks are ever added for PCAP analysis) ──────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints


# ── Temporary & OS Files ──────────────────────────────────────────────────────
*.tmp
*.temp
*.bak
*.orig
*.rej
